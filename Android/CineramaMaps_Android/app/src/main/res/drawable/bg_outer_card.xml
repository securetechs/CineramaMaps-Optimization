<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#FFFFFF" /> <!-- white background -->

    <!-- Stroke: width and color -->
    <stroke
        android:width="2dp"
        android:color="#E7E7E9" /> <!-- subtle gray border -->

    <!-- Rounded corners (pill shape) -->
    <corners android:radius="50dp" />

    <!-- Optional padding (can be removed or adjusted) -->
    <padding
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp" />
</shape>
