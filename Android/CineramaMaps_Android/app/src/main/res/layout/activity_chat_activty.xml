<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layoutDirection="ltr"
    xmlns:shimmer="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/mainlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@color/toolbarcol"
                android:visibility="visible">

                <RelativeLayout
                    android:id="@+id/exit_app_but"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="0dp">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/back"
                        android:backgroundTint="@color/white" />

                </RelativeLayout>


                <main.com.cineramamaps.customfont.BoldTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="5dp"
                    android:layout_toEndOf="@+id/exit_app_but"
                    android:text="@string/chats"
                    android:textColor="@color/white"
                    android:textSize="@dimen/medium"
                    android:textStyle="bold"></main.com.cineramamaps.customfont.BoldTextView>


            </RelativeLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_margin="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mainlay"

            android:gravity="center_horizontal"
            android:orientation="vertical">



            <RelativeLayout
                android:visibility="gone"
                android:id="@+id/sellingrellay"
                android:layout_gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:visibility="gone"
                    android:layout_margin="15dp"
                    android:gravity="center"
                    android:id="@+id/bid_item_msg_tv"
                    android:layout_centerInParent="true"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent" />

                <ListView

                    android:id="@+id/sellinglist"
                    android:divider="@null"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"></ListView>

            </RelativeLayout>
            <RelativeLayout
                android:layout_below="@id/mainlay"
                android:layout_marginTop="10dp"
                android:id="@+id/search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardUseCompatPadding="true">

                    <RelativeLayout

                        android:id="@+id/searchlay"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:backgroundTint="@color/white"
                        android:padding="3dp"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/dddddd"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/search" />

                        <main.com.cineramamaps.customfont.RegularEditView
                            android:id="@+id/search_et"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="5dp"
                            android:layout_toStartOf="@+id/search_bt"
                            android:layout_toEndOf="@+id/dddddd"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/search"
                            android:imeOptions="actionSearch"
                            android:padding="5dp"
                            android:textSize="@dimen/small" />

                        <ImageView
                            android:id="@+id/search_bt"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            android:visibility="gone" />


                    </RelativeLayout>

                </androidx.cardview.widget.CardView>


            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/buyinglayrel"
                android:layout_gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:visibility="gone"
                    android:layout_margin="15dp"
                    android:gravity="center"
                    android:text="@string/nochat"
                    android:id="@+id/selected_item_msg_tv"
                    android:layout_centerInParent="true"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent" />

                <ListView
                    android:id="@+id/buyinglist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@null"
                    android:visibility="gone"></ListView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cat2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:nestedScrollingEnabled="true" />
            </RelativeLayout>


        </LinearLayout>
        <com.facebook.shimmer.ShimmerFrameLayout
            android:layout_below="@+id/mainlay"
            android:visibility="gone"
            android:id="@+id/shimmer_view_food"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:orientation="vertical"
            shimmer:duration="800">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone" />
    </RelativeLayout>

</layout>