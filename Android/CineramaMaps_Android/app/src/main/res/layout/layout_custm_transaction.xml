<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layoutDirection="ltr"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_margin="3dp"

        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/circlelay"
                        android:layout_width="70dp"
                        app:cardCornerRadius="35dp"
                        android:layout_height="70dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/profileic"
                            android:layout_gravity="center"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/topup"></de.hdodenhof.circleimageview.CircleImageView>


                    </androidx.cardview.widget.CardView>



                    <LinearLayout
                        android:layout_centerVertical="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@+id/circlelay"
                        android:gravity="start"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <main.com.cineramamaps.customfont.BoldTextView
                                android:textColor="@color/toolbarcol"
                                android:id="@+id/transactiontypetv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginTop="3dp"
                                android:text="+$500 Top Up Wallet"
                                android:textSize="@dimen/medium"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:gravity="center_vertical"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:orientation="horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <main.com.cineramamaps.customfont.RegularTextView
                                    android:id="@+id/transonlytype"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
android:textColor="@color/toolbarcol"
                                    android:text="@string/topup"
                                    android:textSize="@dimen/extrasmall" />
                                <ImageView
android:layout_marginStart="3dp"
                                    android:src="@drawable/arrow_green_up"
                                    android:layout_width="22dp"
                                    android:layout_height="22dp"></ImageView>

                            </LinearLayout>



                        </RelativeLayout>
<LinearLayout
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <main.com.cineramamaps.customfont.RegularTextView
        android:id="@+id/datetv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:text="Oct 15,2022 - 02:00 PM"
        android:textSize="@dimen/small"
         />

</LinearLayout>


                    </LinearLayout>


                </RelativeLayout>




            </LinearLayout>

        </androidx.cardview.widget.CardView>


    </RelativeLayout>
</layout>