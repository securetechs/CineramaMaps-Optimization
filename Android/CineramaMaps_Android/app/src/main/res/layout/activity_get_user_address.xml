<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layoutDirection="ltr"
    xmlns:shimmer="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:id="@+id/mainlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@color/toolbarcol"
                android:visibility="visible">

                <RelativeLayout
                    android:id="@+id/exit_app_but"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="0dp">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/back"
                        android:backgroundTint="@color/white" />

                </RelativeLayout>


                <main.com.cineramamaps.customfont.BoldTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="5dp"
                    android:layout_toEndOf="@+id/exit_app_but"
                    android:text="@string/savedaddress"
                    android:textColor="@color/white"
                    android:textSize="@dimen/medium"
                    android:textStyle="bold"></main.com.cineramamaps.customfont.BoldTextView>


            </RelativeLayout>
        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_margin="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mainlay"

            android:gravity="center_horizontal"
            android:orientation="vertical">



            <RelativeLayout
                android:id="@+id/menulay"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="50dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/get_add_recycerview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                   >

                </androidx.recyclerview.widget.RecyclerView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:id="@+id/nodata"
                    android:visibility="gone"
                    android:text="@string/noaddressadded"></TextView>



            </RelativeLayout>

        </LinearLayout>
        <com.facebook.shimmer.ShimmerFrameLayout
            android:layout_below="@+id/mainlay"
            android:visibility="gone"
            android:id="@+id/shimmer_view_food"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="15dp"
            android:orientation="vertical"
            shimmer:duration="800">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />
                <include layout="@layout/shimmer_big_food_lay" />

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>
        <Button
            android:id="@+id/address_continue_btn"
            style="@style/TextAppearance.AppCompat.Medium"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_marginLeft="0dp"
            android:layout_marginRight="0dp"
            android:background="@drawable/button_round_dra"
            android:backgroundTint="@color/toolbarcol"
            android:text="@string/addnewaddress"
            android:textColor="@color/white"
            android:visibility="visible" />
        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone" />
    </RelativeLayout>

</layout>