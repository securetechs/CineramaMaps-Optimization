<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:shimmer="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layoutDirection="ltr">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fitsSystemWindows="true"
        android:focusableInTouchMode="true">

        <androidx.cardview.widget.CardView
            android:id="@+id/mainlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@color/toolbarcol"
                android:visibility="visible">

                <androidx.cardview.widget.CardView
                    android:id="@+id/exit_app_but"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:visibility="gone"
                    app:cardCornerRadius="40dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_gravity="center"
                        android:background="@drawable/back"
                        android:backgroundTint="@color/colorPrimary" />

                </androidx.cardview.widget.CardView>


                <main.com.cineramamaps.customfont.BoldTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/services"
                    android:textColor="@color/white"
                    android:textSize="@dimen/large"
                    android:textStyle="bold"></main.com.cineramamaps.customfont.BoldTextView>

                <RelativeLayout
                    android:id="@+id/cart"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_toStartOf="@+id/fav"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/mycart" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/fav"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="10dp"
                    android:layout_marginEnd="10dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/notification_bell" />

                </RelativeLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/datalay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/mainlay"
            android:layout_marginStart="15dp"
            android:layout_marginTop="15dp"

            android:layout_marginEnd="15dp"
            android:layout_marginBottom="15dp"
            android:background="@color/white"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="visible">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/grey_round_edge_back"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="3">

                <main.com.cineramamaps.customfont.BoldTextView
                    android:id="@+id/inprogresstv"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_round_dra"
                    android:gravity="center"
                    android:text="@string/tourism"
                    android:textColor="@color/white"
                    android:textSize="16dp">

                </main.com.cineramamaps.customfont.BoldTextView>

                <main.com.cineramamaps.customfont.BoldTextView
                    android:id="@+id/completedtv"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/partner"
                    android:textColor="@color/colorPrimary"
                    android:textSize="16dp">

                </main.com.cineramamaps.customfont.BoldTextView>

                <main.com.cineramamaps.customfont.BoldTextView
                    android:id="@+id/offertv"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/cineramaoffers"
                    android:textColor="@color/colorPrimary"
                    android:textSize="16dp">

                </main.com.cineramamaps.customfont.BoldTextView>

            </LinearLayout>


            <LinearLayout
                android:id="@+id/inprogresslay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/inprogressRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="visible"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/subinprogressRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/childinprogressRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/lay1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/btnlay"
                    android:layout_marginBottom="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardUseCompatPadding="true">

                    <RelativeLayout
                        android:id="@+id/searchlay"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:backgroundTint="@color/white"
                        android:padding="3dp"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/dddddd"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/search" />

                        <main.com.cineramamaps.customfont.RegularEditView
                            android:id="@+id/search_et"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="5dp"
                            android:layout_toStartOf="@+id/search_bt"
                            android:layout_toEndOf="@+id/dddddd"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/searchdata"
                            android:imeOptions="actionSearch"
                            android:padding="5dp"
                            android:textSize="@dimen/small" />

                        <ImageView
                            android:id="@+id/search_bt"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/filterbutton"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/filternew"
                            android:visibility="gone" />
                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/inprogressrecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager">

                </androidx.recyclerview.widget.RecyclerView>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/completedlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/completeRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="visible"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/subcompleteRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/childcompleteRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardUseCompatPadding="true">

                    <RelativeLayout
                        android:id="@+id/searchlay1"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:backgroundTint="@color/white"
                        android:padding="3dp"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/dddddd1"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/search" />

                        <main.com.cineramamaps.customfont.RegularEditView
                            android:id="@+id/search_et1"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="5dp"
                            android:layout_toStartOf="@+id/search_bt1"
                            android:layout_toEndOf="@+id/dddddd1"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/searchdata"
                            android:imeOptions="actionSearch"
                            android:padding="5dp"
                            android:textSize="@dimen/small" />

                        <ImageView
                            android:id="@+id/search_bt1"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/filterbutton1"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/filternew"
                            android:visibility="gone" />
                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/completedrecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"></androidx.recyclerview.widget.RecyclerView>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/offerlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="0dp"
                    android:visibility="gone"
                    app:cardCornerRadius="20dp"
                    app:cardUseCompatPadding="true">

                    <RelativeLayout
                        android:id="@+id/searchlay2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:backgroundTint="@color/white"
                        android:padding="3dp"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/dddddd2"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/search" />

                        <main.com.cineramamaps.customfont.RegularTextView
                            android:id="@+id/search_et2"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="5dp"
                            android:layout_toStartOf="@+id/search_bt2"
                            android:layout_toEndOf="@+id/dddddd2"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/searchdata"
                            android:imeOptions="actionSearch"
                            android:padding="5dp"
                            android:textSize="@dimen/small" />

                        <ImageView
                            android:id="@+id/search_bt2"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            android:visibility="gone" />

                        <ImageView
                            android:id="@+id/filterbutton2"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/filternew"
                            android:visibility="gone" />
                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/completedrecycler2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager">

                </androidx.recyclerview.widget.RecyclerView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/categoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="visible"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/subCategoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/childCategoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:overScrollMode="never"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="gone"
                    tools:listitem="@layout/custom_tab" />


                <androidx.cardview.widget.CardView
                    android:id="@+id/lay2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/btnlay"
                    android:layout_marginBottom="0dp"
                    app:cardCornerRadius="20dp"
                    app:cardUseCompatPadding="true">

                    <RelativeLayout
                        android:id="@+id/searchla2"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:backgroundTint="@color/white"
                        android:padding="3dp"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/dddddd12"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/search" />

                        <main.com.cineramamaps.customfont.RegularEditView
                            android:id="@+id/search_e2"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="5dp"
                            android:layout_toStartOf="@+id/search_btn"
                            android:layout_toEndOf="@+id/dddddd12"
                            android:background="@null"
                            android:gravity="center_vertical"
                            android:hint="@string/searchdata"
                            android:imeOptions="actionSearch"
                            android:padding="5dp"
                            android:textSize="@dimen/small" />

                        <ImageView
                            android:id="@+id/search_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:rotation="180"
                            android:src="@drawable/ic_back"
                            android:visibility="gone" />


                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/offer_rv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:visibility="visible"
                    tools:listitem="@layout/custom_tab" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/emptylay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/mainlay"
            android:layout_marginTop="120dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_marginStart="70dp"
                android:layout_marginEnd="70dp"
                android:src="@drawable/empty_cart"></ImageView>


            <main.com.cineramamaps.customfont.BoldTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:gravity="center"
                android:text="@string/nodata"
                android:textColor="@color/black"
                android:textSize="@dimen/extralarge"></main.com.cineramamaps.customfont.BoldTextView>


        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="gone" />

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_view_myorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mainlay"
            android:layout_gravity="center"
            android:layout_marginTop="100dp"
            android:orientation="vertical"
            android:visibility="gone"
            shimmer:duration="800">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <include layout="@layout/shimmer_orders_view" />

                <include layout="@layout/shimmer_orders_view" />

                <include layout="@layout/shimmer_orders_view" />

                <include layout="@layout/shimmer_orders_view" />

                <include layout="@layout/shimmer_orders_view" />

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>


    </RelativeLayout>

</layout>