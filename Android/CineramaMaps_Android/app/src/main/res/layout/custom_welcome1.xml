<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="ltr">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">
        <ProgressBar
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:visibility="gone"
            android:layout_centerInParent="true"></ProgressBar>

        <ImageView
            android:id="@+id/image_but"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_centerInParent="true"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:scaleType="fitXY"
            android:src="@drawable/slide_3"></ImageView>

        <TextView
            android:id="@+id/msgtv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/image_but"
            android:layout_marginTop="50dp"
            android:gravity="center"
            android:textColor="@color/slidetextcolor"
            android:textSize="25dp"
            android:textStyle="normal"
            android:visibility="visible" />

        <TextView
            android:id="@+id/msgtv1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/msgtv"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:textColor="@color/slidetextcolor"

            android:textSize="15dp"
            android:textStyle="normal"
            android:visibility="visible" />


    </RelativeLayout></LinearLayout>