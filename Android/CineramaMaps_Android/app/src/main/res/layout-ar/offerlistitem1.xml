<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:layoutDirection="rtl"
    app:cardUseCompatPadding="true"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            >

            <ImageView
                android:id="@+id/img_service"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:background="@drawable/offer2"
                android:scaleType="fitXY"
                android:visibility="visible"/>

            <LinearLayout
                android:background="@color/lightgreytrans"
                android:padding="10dp"
                android:layout_alignParentBottom="true"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/code_tv"
                    android:textColor="@color/white"
                    android:textSize="@dimen/medium"
                    android:textStyle="bold"
                    android:text="QWE123"
                    android:layout_gravity="start"
                    android:gravity="start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"></TextView>
                <TextView
                    android:id="@+id/code_percent"
                    android:textColor="@color/white"
                    android:textSize="@dimen/medium"
                    android:text="12%"
                    android:layout_gravity="start"
                    android:gravity="start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"></TextView>
                <TextView
                    android:id="@+id/code_description"
                    android:textColor="@color/white"
                    android:textSize="@dimen/extrasmall"
                    android:layout_gravity="start"
                    android:gravity="start"
                    android:text="use this code at the time of order and get flat discount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"></TextView>

            </LinearLayout>




        </RelativeLayout>







    </LinearLayout>


</androidx.cardview.widget.CardView>