<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layoutDirection="rtl"
    tools:context=".activity.SignupActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <androidx.cardview.widget.CardView
            android:id="@+id/mainlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:visibility="visible">
                <RelativeLayout
                    android:id="@+id/exit_app_but"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="0dp">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_centerInParent="true"
                        android:rotation="180"
                        android:background="@drawable/back"
                        android:backgroundTint="@color/black" />

                </RelativeLayout>


                <main.com.cineramamaps.customfont.BoldTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="5dp"
                    android:layout_toEndOf="@+id/exit_app_but"
                    android:text="@string/forgotpass_txt"
                    android:textColor="@color/black"
                    android:textSize="@dimen/medium"></main.com.cineramamaps.customfont.BoldTextView>


            </RelativeLayout>
        </androidx.cardview.widget.CardView>

    <ScrollView
        android:layout_below="@+id/mainlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">




        <LinearLayout
            android:gravity="center"
            android:layout_margin="10dp"

            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <androidx.cardview.widget.CardView
                app:cardCornerRadius="10dp"
                android:layout_margin="20dp"
                android:elevation="5dp"

                android:layout_below="@+id/mainlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_marginRight="10dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginTop="30dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:orientation="vertical">
                    <main.com.cineramamaps.customfont.BoldTextView
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="center_horizontal"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:textSize="@dimen/extralarge"
                        android:textStyle="bold"
                        android:text="@string/forgotpass_txt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <main.com.cineramamaps.customfont.RegularTextView
                        android:layout_marginStart="20dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="center_horizontal"
                        android:gravity="center"
                        android:textSize="@dimen/small"
                        android:text="@string/enteryouremailaddtoreset"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <View
                        android:visibility="gone"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="7dp"
                        android:background="@color/darkgrey"
                        android:layout_gravity="center_horizontal"
                        android:layout_width="80dp"
                        android:layout_height="0.5dp"></View>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="15dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <main.com.cineramamaps.customfont.RegularEditView
                            android:background="@drawable/edit_round_dra"
                            android:id="@+id/phone_et"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:padding="10dp"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:hint="@string/email"
                            android:inputType="text"
                            />

                    </LinearLayout>






                    <main.com.cineramamaps.customfont.BoldTextView
                        android:layout_marginBottom="35dp"
                        android:layout_marginRight="15dp"
                        android:layout_marginLeft="15dp"
                        android:layout_marginTop="30dp"
                        android:id="@+id/submit"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:text="@string/send"
                        android:textSize="@dimen/medium"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/button_round_dra"
                        android:layout_width="match_parent"
                        android:layout_height="55dp" />


                </LinearLayout>


            </androidx.cardview.widget.CardView>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:gravity="center"
                            android:layout_width="match_parent"
                            android:layout_height="35dp"
                            android:visibility="gone">

                        </LinearLayout>


                        <EditText
                            android:visibility="gone"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="5dp"
                            android:background="@null"
                            android:imeOptions="actionNext"
                            android:inputType="phone"
                            android:maxLength="35"
                            android:padding="5dp"
                            android:text="+1"
                            android:textColor="@color/white"
                            android:textColorHint="@color/white"
                            android:textSize="@dimen/medium" />


                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/black"></View>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="2"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/phone_et1"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:background="@null"
                        android:hint="@string/enter"
                        android:imeOptions="actionNext"
                        android:inputType="phone"
                        android:maxLength="35"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/darkgrey"
                        android:textSize="@dimen/medium" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/black"></View>

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/successlay"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/extralarge"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    android:id="@+id/mobiletv"
                    android:textSize="@dimen/extralarge"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:text=""
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>





        </LinearLayout>

    </ScrollView>
<ProgressBar
    android:visibility="gone"
    android:id="@+id/prgressbar"
    android:layout_centerInParent="true"
    android:layout_width="40dp"
    android:layout_height="40dp" />
    </RelativeLayout>
</layout>
