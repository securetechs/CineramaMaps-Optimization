<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"

    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activity_about_us"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:focusableInTouchMode="true"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/toplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout

            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:visibility="visible">

            <RelativeLayout
                android:id="@+id/exit_app_but"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_marginLeft="0dp">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:rotation="180"
                    android:layout_centerInParent="true"
                    android:background="@drawable/back"
                    android:backgroundTint="@color/black" />

            </RelativeLayout>

            <main.com.cineramamaps.customfont.BoldTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="5dp"
                android:layout_toEndOf="@+id/exit_app_but"
                android:text="@string/findyourshop"
                android:textColor="@color/black"
                android:textSize="@dimen/medium"
                android:textStyle="bold"></main.com.cineramamaps.customfont.BoldTextView>


        </RelativeLayout>
    </androidx.cardview.widget.CardView>



    <RelativeLayout
        android:layout_below="@+id/toplay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

                android:layout_marginTop="10dp"
                android:orientation="vertical">



                <LinearLayout
                    android:id="@+id/receivedcartlistview_lay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:orientation="vertical"
                    android:layout_marginEnd="15dp"
                    android:visibility="visible">

                    <RelativeLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="350dp">


                        <fragment
                            android:id="@+id/map"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                        <ImageView
                            android:src="@drawable/ic_pin"
                            android:layout_centerInParent="true"
                            android:layout_width="30dp"
                            android:layout_height="50dp" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/dddd"
                            style="@style/TextAppearance.AppCompat.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="15dp"
                            android:text="@string/selectadistance"
                            android:textColor="@color/black"
                            android:textSize="18dp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/distancetv"
                            style="@style/TextAppearance.AppCompat.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="15dp"
                            android:layout_toEndOf="@+id/dddd"
                            android:text="10 km"
                            android:textColor="@color/toolbarcol"
                            android:textSize="18dp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </RelativeLayout>


                    <SeekBar
                        android:id="@+id/distanceseekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/h2"
                        android:layout_marginLeft="0dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="0dp"
                        android:progress="10"
                        android:max="50"
                        android:visibility="gone">
                    </SeekBar>

                    <RelativeLayout
                        android:id="@+id/v1"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginStart="20dp"
                        android:layout_below="@+id/welcometxt"
                        android:layout_marginTop="20dp"
                        android:layout_marginEnd="20dp"
                        android:background="@drawable/edittextbg">

                        <ImageView
                            android:id="@+id/imagename_lay1"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerVertical="true"
                            android:layout_marginLeft="15dp"
                            android:layout_marginRight="10dp"
                            android:background="@drawable/search"
                            android:visibility="visible"></ImageView>

                        <RelativeLayout
                            android:id="@+id/edit_lay1"
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:layout_centerVertical="true"
                            android:layout_marginLeft="0dp"
                            android:layout_toRightOf="@+id/imagename_lay1">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <AutoCompleteTextView
                                    android:id="@+id/pickuplocation"
                                    android:layout_width="match_parent"
                                    android:layout_height="45dp"
                                    android:layout_centerVertical="true"
                                    android:layout_marginLeft="5dp"
                                    android:layout_toLeftOf="@+id/clear_pick_ic"
                                    android:background="@null"
                                    android:hint="@string/setlocation"
                                    android:inputType="textNoSuggestions"
                                    android:padding="5dp"
                                    android:singleLine="true"
                                    android:textColor="@color/black"
                                    android:textSize="14dp" />
                                <ImageView
                                    android:layout_centerVertical="true"
                                    android:layout_marginRight="10dp"
                                    android:layout_alignParentRight="true"
                                    android:id="@+id/clear_pick_ic"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_cancel"
                                    android:visibility="visible" />

                            </RelativeLayout>

                        </RelativeLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:visibility="gone"
                        android:id="@+id/createaccountlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/login_lay"
                        android:layout_centerHorizontal="true"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="25dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_marginLeft="0dp"
                            android:layout_marginRight="0dp"
                            android:background="@drawable/sendbtnbg"
                            android:textSize="17dp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="0dp"
                            android:text="@string/usemycurrentlocation"
                            android:textColor="@color/toolbarcol"
                            android:textSize="17dp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>



                    <RelativeLayout
                        android:id="@+id/done_loc"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="45dp"
                        android:layout_marginRight="20dp"
                        android:background="@drawable/button_round_dra"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="@string/choosethislocation"
                            android:textColor="@color/white"
                            android:textSize="18dp"
                            android:textStyle="bold"></TextView>
                    </RelativeLayout>


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"></RelativeLayout>


                </LinearLayout>
            </LinearLayout>

        </LinearLayout>


    </RelativeLayout>
    <ImageView
        android:visibility="gone"
        android:id="@+id/gpslocator"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="60dp"
        android:layout_marginRight="10dp"
        android:layout_alignParentRight="true"
        android:layout_width="30dp"
        android:layout_height="30dp" />
    <ProgressBar
        android:visibility="gone"
        android:id="@+id/prgressbar"
        android:layout_centerInParent="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</RelativeLayout>
