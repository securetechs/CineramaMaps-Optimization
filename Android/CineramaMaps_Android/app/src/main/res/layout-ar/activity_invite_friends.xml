<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layoutDirection="rtl"
    xmlns:tools="http://schemas.android.com/tools">
<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/mainlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
    <RelativeLayout

        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:visibility="visible">

        <RelativeLayout
            android:id="@+id/exit_app_but"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="0dp">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:rotation="180"
                android:layout_centerInParent="true"
                android:background="@drawable/back"
                android:backgroundTint="@color/black" />

        </RelativeLayout>


        <main.com.cineramamaps.customfont.BoldTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="5dp"
            android:layout_toEndOf="@+id/exit_app_but"
            android:text="@string/invitefriend"
            android:textColor="@color/black"
            android:textSize="@dimen/medium"
            android:textStyle="bold"></main.com.cineramamaps.customfont.BoldTextView>


    </RelativeLayout>
    </androidx.cardview.widget.CardView>
<ScrollView
    android:layout_below="@+id/mainlay"
    android:layout_width="match_parent"
    android:fillViewport="true"
    android:background="@color/white"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:layout_marginStart="25dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="10dp"
        android:orientation="vertical">


<ImageView
    android:src="@drawable/invitefriend_big_ic"
    android:layout_width="match_parent"
    android:layout_height="220dp"></ImageView>


<main.com.cineramamaps.customfont.BoldTextView
    android:layout_marginTop="30dp"
    android:gravity="center"
    android:textSize="@dimen/medium"
    android:textColor="@color/black"
    android:textStyle="bold"
    android:text="@string/inviteyourfrient"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"></main.com.cineramamaps.customfont.BoldTextView>
<main.com.cineramamaps.customfont.RegularTextView
    android:layout_marginTop="5dp"
    android:gravity="center"
    android:textSize="@dimen/small"
    android:textColor="@color/black"
    android:layout_marginEnd="20dp"
    android:layout_marginStart="20dp"
    android:text="@string/yougetdiscounts"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"></main.com.cineramamaps.customfont.RegularTextView>



<ImageView
    android:id="@+id/exit_app_but1"
    android:layout_marginTop="20dp"
    android:layout_gravity="center_horizontal"
    android:src="@drawable/plus_grey"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"></ImageView>






    </LinearLayout>

</ScrollView>
<ProgressBar
    android:visibility="gone"
    android:id="@+id/progressbar"
    android:layout_centerInParent="true"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"></ProgressBar>
</RelativeLayout>

</layout>